---
/* TEMPLATE: Update agent names, titles, photos, and links for each community */
const agents = [
  {
    name: 'Alexis Roemer',
    title: 'Senior Sales Specialist',
    badge: 'REALTOR®',
    image: 'https://cbhhomes.com/content/uploads/2024/10/CBH-Homes-Sales-Team-Website-Headshot_ALEXIS-533x800.jpg',
    link: 'https://cbhhomes.com/agent/alexis-roemer-2/',
  },
  {
    name: 'Nick Hafner',
    title: 'Sales Coach',
    badge: 'REALTOR®',
    image: 'https://cbhhomes.com/content/uploads/2024/10/CBH-Homes-Sales-Team-Website-Headshot_NICK-533x800.jpg',
    link: 'https://cbhhomes.com/agent/nick-hafner/',
  },
];
---

<section class="section-padding bg-cbh-light">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-display text-3xl sm:text-4xl font-bold text-cbh-dark mb-4">
      Meet Your Beaconwood Sales Team
    </h2>
    <p class="text-lg text-cbh-slate mb-10">
      Your local experts are here to help. No pressure, just honest guidance.
    </p>

    <div class="grid sm:grid-cols-2 gap-8 max-w-2xl mx-auto mb-10">
      {agents.map(agent => (
        <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-200">
          <img
            src={agent.image}
            alt={`${agent.name} - ${agent.title} at CBH Homes Beaconwood`}
            class="w-full h-64 object-cover"
            loading="lazy"
          />
          <div class="p-5">
            <h3 class="font-display text-lg font-bold text-cbh-dark">{agent.name}</h3>
            <p class="text-sm text-cbh-slate/70 mb-1">{agent.title}</p>
            <span class="inline-block text-xs bg-cbh-light text-cbh-slate font-medium px-2 py-0.5 rounded-full mb-4">
              {agent.badge}
            </span>
            <a
              href={agent.link}
              target="_blank"
              rel="noopener"
              class="block w-full text-center bg-white border-2 border-cbh-red text-cbh-red font-semibold py-2.5 rounded-md hover:bg-cbh-red hover:text-white transition-all duration-200"
            >
              Learn More
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Phone CTA -->
    <a href="tel:2083915545" class="inline-flex items-center gap-2 text-cbh-red font-semibold text-lg hover:underline">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      (208) 391-5545
    </a>
  </div>
</section>
