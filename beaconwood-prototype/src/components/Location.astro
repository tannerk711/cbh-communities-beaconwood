---
/* TEMPLATE: Update proximity callouts, map coordinates, and directions for each community */
const proximityCards = [
  { icon: 'shopping', place: 'Eagle Road Shopping', time: '~5 min' },
  { icon: 'coffee', place: 'Downtown Eagle', time: '~5 min' },
  { icon: 'park', place: 'Eagle Island State Park', time: '~10 min' },
  { icon: 'medical', place: "St. Luke's Medical Center", time: '~15 min' },
  { icon: 'city', place: 'Downtown Boise', time: '~20 min' },
  { icon: 'ski', place: 'Bogus Basin', time: '~45 min' },
];
---

<section id="location" class="section-padding bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-cbh-dark mb-4">
        Perfectly Placed in Eagle, Idaho
      </h2>
      <p class="text-lg text-cbh-slate max-w-2xl mx-auto">
        Minutes from everything that makes the Treasure Valley special.
      </p>
    </div>

    <!-- Proximity Cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
      {proximityCards.map(card => (
        <div class="flex items-center gap-4 bg-cbh-light rounded-lg p-5 hover:shadow-md transition-shadow duration-200">
          <div class="w-10 h-10 rounded-full bg-cbh-red/10 flex items-center justify-center shrink-0">
            {card.icon === 'shopping' && (
              <svg class="w-5 h-5 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            )}
            {card.icon === 'coffee' && (
              <svg class="w-5 h-5 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h18v4H3V3zm0 4v10a2 2 0 002 2h14a2 2 0 002-2V7"/></svg>
            )}
            {card.icon === 'park' && (
              <svg class="w-5 h-5 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
            )}
            {card.icon === 'medical' && (
              <svg class="w-5 h-5 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
            )}
            {card.icon === 'city' && (
              <svg class="w-5 h-5 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            )}
            {card.icon === 'ski' && (
              <svg class="w-5 h-5 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21l9-9m0 0l3-3m-3 3l-3-3m3 3l3 3M12 3v6"/></svg>
            )}
          </div>
          <div class="flex-1">
            <p class="font-semibold text-cbh-dark text-sm">{card.place}</p>
          </div>
          <span class="text-sm font-bold text-cbh-red whitespace-nowrap">{card.time}</span>
        </div>
      ))}
    </div>

    <!-- Google Map Embed -->
    <!-- TEMPLATE: Update map coordinates for each community -->
    <div class="rounded-xl overflow-hidden shadow-lg">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2886.5!2d-116.423028!3d43.71822!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDPCsDQzJzA1LjYiTiAxMTbCsDI1JzIyLjkiVw!5e0!3m2!1sen!2sus!4v1"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Beaconwood community location - Eagle, Idaho"
        class="w-full"
      ></iframe>
    </div>

    <!-- Directions -->
    <div class="mt-8 bg-cbh-light rounded-lg p-6">
      <h3 class="font-semibold text-cbh-dark mb-2">Directions to Beaconwood</h3>
      <p class="text-sm text-cbh-slate leading-relaxed">
        From I-84, take Exit 42 and head north on Ten Mile Rd. Turn right onto Chinden Blvd, then turn left onto Linder Rd and left on Floating Feather Rd. Take a right on Lanewood Rd and finally turn right onto Yarnell St to enter the community.
      </p>
      <p class="text-sm text-cbh-slate/70 mt-2">5459 W Yarnell St, Eagle, Idaho 83616</p>
    </div>
  </div>
</section>
