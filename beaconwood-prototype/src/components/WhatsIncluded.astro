---
/* TEMPLATE: Update included features list for each community based on interior level */
const features = [
  {
    icon: 'quartz',
    title: 'Quartz Countertops',
    desc: 'Premium quartz surfaces throughout kitchen and bathrooms',
  },
  {
    icon: 'tile',
    title: 'Designer Tile Bathrooms',
    desc: '12x24 format tile in tub surrounds and fireplace',
  },
  {
    icon: 'floor',
    title: 'Luxury Vinyl Plank Flooring',
    desc: 'Durable, beautiful LVP in all main living areas',
  },
  {
    icon: 'cabinet',
    title: 'Greyloch Cabinetry',
    desc: 'Premium cabinets in your choice of three designer finishes',
  },
  {
    icon: 'appliance',
    title: 'Stainless Steel Appliances',
    desc: 'Full suite of modern stainless appliances included [PLACEHOLDER]',
  },
  {
    icon: 'energy',
    title: 'Energy-Efficient Construction',
    desc: 'Built to modern energy standards for lower utility bills [PLACEHOLDER]',
  },
  {
    icon: 'warranty',
    title: '1-2-6 Builder Warranty',
    desc: '1yr workmanship, 2yr mechanical, 6yr structural coverage',
  },
  {
    icon: 'hardware',
    title: 'Coordinated Hardware & Fixtures',
    desc: 'Matching faucets, pulls, and accessories in every room',
  },
];
---

<section id="included" class="section-padding bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-cbh-dark mb-4">
        What's Included in Every Beaconwood Home
      </h2>
      <p class="text-lg text-cbh-slate max-w-2xl mx-auto">
        No surprise upgrade fees. Level 5 & 6 finishes are standard in every home.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map(f => (
        <div class="bg-cbh-light rounded-xl p-6 hover:shadow-md transition-shadow duration-200">
          <div class="w-12 h-12 rounded-lg bg-cbh-red/10 flex items-center justify-center mb-4">
            {f.icon === 'quartz' && (
              <svg class="w-6 h-6 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            )}
            {f.icon === 'tile' && (
              <svg class="w-6 h-6 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM14 5a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zM14 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"/></svg>
            )}
            {f.icon === 'floor' && (
              <svg class="w-6 h-6 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            )}
            {f.icon === 'cabinet' && (
              <svg class="w-6 h-6 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
            )}
            {f.icon === 'appliance' && (
              <svg class="w-6 h-6 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            )}
            {f.icon === 'energy' && (
              <svg class="w-6 h-6 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            )}
            {f.icon === 'warranty' && (
              <svg class="w-6 h-6 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            )}
            {f.icon === 'hardware' && (
              <svg class="w-6 h-6 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            )}
          </div>
          <h3 class="font-semibold text-cbh-dark mb-1">{f.title}</h3>
          <p class="text-sm text-cbh-slate/70 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
