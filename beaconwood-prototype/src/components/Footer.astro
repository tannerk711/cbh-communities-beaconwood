---
/* STATIC: Footer remains mostly the same across all communities (update address and phone) */
import logoDesktop from '../assets/CBH-Built-Different-Logo-Desktop.png';
import logoMobile from '../assets/CBH-Built-Different-Logo-Mobile.png';

const navLinks = [
  { label: 'Homes', href: 'https://cbhhomes.com/homes/' },
  { label: 'Communities', href: 'https://cbhhomes.com/communities/' },
  { label: 'Rentals', href: 'https://cbhhomes.com/rentals/' },
  { label: 'About', href: 'https://cbhhomes.com/about/' },
  { label: 'Contact', href: 'https://cbhhomes.com/contact-us/' },
  { label: 'Warranty', href: 'https://cbhhomes.com/warranty/' },
  { label: 'Privacy Policy', href: 'https://cbhhomes.com/privacy-policy/' },
];

const socials = [
  { label: 'Facebook', href: 'https://facebook.com/cbhhomes', icon: 'facebook' },
  { label: 'Instagram', href: 'https://instagram.com/cbhhomes', icon: 'instagram' },
  { label: 'YouTube', href: 'https://youtube.com/user/cbhguru', icon: 'youtube' },
  { label: 'TikTok', href: 'https://tiktok.com/@cbhhomes', icon: 'tiktok' },
];
---

<footer class="bg-neutral-800 text-white/70">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Logo & Info -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="mb-4">
          <a href="https://cbhhomes.com" aria-label="CBH Homes">
            <img src={logoDesktop.src} alt="CBH Homes - Built Different" class="hidden sm:block h-8 w-auto brightness-0 invert" loading="lazy" />
            <img src={logoMobile.src} alt="CBH Homes - Built Different" class="sm:hidden h-7 w-auto brightness-0 invert" loading="lazy" />
          </a>
        </div>
        <p class="text-sm mb-4">Idaho's #1 Homebuilder</p>
        <!-- TEMPLATE: Update address for each community -->
        <p class="text-sm">5459 W Yarnell St</p>
        <p class="text-sm">Eagle, Idaho 83616</p>
        <a href="tel:2083915545" class="text-sm text-cbh-red hover:text-white transition-colors mt-2 inline-block">
          (208) 391-5545
        </a>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Quick Links</h4>
        <ul class="space-y-2">
          {navLinks.map(link => (
            <li>
              <a href={link.href} target="_blank" rel="noopener" class="text-sm hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Community Links -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Beaconwood</h4>
        <ul class="space-y-2">
          <li><a href="#overview" class="text-sm hover:text-white transition-colors">Community Overview</a></li>
          <li><a href="#homes" class="text-sm hover:text-white transition-colors">Available Homes</a></li>
          <li><a href="#interiors" class="text-sm hover:text-white transition-colors">Designer Interiors</a></li>
          <li><a href="#amenities" class="text-sm hover:text-white transition-colors">Amenities</a></li>
          <li><a href="#location" class="text-sm hover:text-white transition-colors">Location & Map</a></li>
          <li><a href="#contact" class="text-sm hover:text-white transition-colors">Contact Sales</a></li>
          <li><a href="#faq" class="text-sm hover:text-white transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Follow Us</h4>
        <div class="flex gap-3 mb-6">
          {socials.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              aria-label={s.label}
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-cbh-red transition-colors duration-200"
            >
              {s.icon === 'facebook' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              )}
              {s.icon === 'instagram' && (
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" /><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" /><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" /></svg>
              )}
              {s.icon === 'youtube' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.43z"/><polygon fill="#262626" points="9.75,15.02 15.5,11.75 9.75,8.48"/></svg>
              )}
              {s.icon === 'tiktok' && (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-.81.07l-.38-.27z"/></svg>
              )}
            </a>
          ))}
        </div>
        <a href="https://cbhhomes.com/tour-now/" target="_blank" rel="noopener" class="inline-block bg-cbh-red text-white font-semibold px-6 py-3 rounded-md hover:bg-cbh-red-dark transition-colors text-sm">
          Schedule a Tour
        </a>
      </div>
    </div>
  </div>

  <!-- Legal -->
  <div class="border-t border-white/10 bg-black/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="text-xs text-white/40 space-y-2">
        <p>&copy; 2026 CBH Sales & Marketing, Inc. All rights reserved.</p>
        <p>CBH Sales & Marketing is a licensed brokerage in the state of Idaho. RCE-923.</p>
        <p>Lifestyle photography does not reflect any ethnic or racial preference. THIS IS AN ARTISTIC REPRESENTATION. Buyer and/or Buyer's Agent to verify all information with a CBH Homes representative.</p>
        <p>Financing by Premier Mortgage Resources, NMLS #1169 | Mandi Feely-Swain, NMLS #38490 | Some restrictions apply. See a CBH sales specialist for complete details.</p>
      </div>
    </div>
  </div>
</footer>
