---
/* TEMPLATE: Update community name, price, H1, subheading, and hero image for each community */
---

<section class="relative min-h-[90vh] flex items-end pt-10" id="hero">
  <!-- Hero Background Image -->
  <div class="absolute inset-0">
    <img
      src="/hero-background.png"
      alt="New homes in Eagle Idaho - Beaconwood by CBH Homes - luxury new construction exterior"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20"></div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 w-full">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24 md:pb-32">
      <!-- TEMPLATE: Update eyebrow, H1, and subheading for each community -->
      <p class="text-cbh-red font-semibold text-sm tracking-widest uppercase mb-4">
        CBH Homes&ensp;|&ensp;Eagle, Idaho
      </p>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl mb-6">
        New Homes in Eagle, Idaho | Beaconwood by CBH Homes
      </h1>
      <p class="text-lg sm:text-xl text-white/90 max-w-2xl mb-10 leading-relaxed">
        Move-in ready luxury homes from $694,990. Level 5 &amp; 6 finishes. Scenic Bogus Basin views.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#homes" class="inline-flex items-center justify-center bg-cbh-red text-white font-semibold px-8 py-4 rounded-md hover:bg-cbh-red-dark hover:scale-[1.02] transition-all duration-200 text-center">
          View Available Homes
        </a>
        <a href="https://cbhhomes.com/tour-now/" target="_blank" rel="noopener" class="inline-flex items-center justify-center bg-white/10 backdrop-blur-sm border-2 border-white text-white font-semibold px-8 py-4 rounded-md hover:bg-white hover:text-cbh-dark hover:scale-[1.02] transition-all duration-200 text-center">
          Book a Self-Guided Tour
        </a>
      </div>
    </div>

    <!-- Trust Badges Strip -->
    <!-- STATIC: Trust badges pattern remains the same (update stats if they change) -->
    <div class="bg-black/50 backdrop-blur-sm border-t border-white/10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-12 text-white/90 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-cbh-red" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span class="font-semibold">Idaho's #1 Builder</span>
          </div>
          <div class="hidden sm:block w-px h-5 bg-white/20"></div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="font-semibold">34 Years Experience</span>
          </div>
          <div class="hidden sm:block w-px h-5 bg-white/20"></div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-cbh-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="font-semibold">29,000+ Happy Homeowners</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
